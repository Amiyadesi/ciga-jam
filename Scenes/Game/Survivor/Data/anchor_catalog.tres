[resource]
script = ExtResource("1_catalog")
entries = {
"double_xiu_xiu": {
"description": "每次同时发射两枚魔法弹，攻击范围内距离最近的敌人。",
"display_name": "双发咻咻",
"levels": [ExtResource("5_d1"), ExtResource("6_d2"), ExtResource("7_d3")],
"short_name": "双发"
},
"frost_circle": {
"description": "持续降低范围内所有敌人的移动速度，不会成为敌人的攻击目标。",
"display_name": "寒冰法阵",
"levels": [ExtResource("11_f1"), ExtResource("12_f2"), ExtResource("13_f3")],
"short_name": "寒冰"
},
"frost_tower": {
"description": "发射可贯穿敌人的冰锥，对路径上的多个敌人造成伤害；每穿透一个敌人，伤害都会衰减，并对命中的敌人造成减速效果。",
"display_name": "冰霜塔",
"levels": [ExtResource("17_ft1"), ExtResource("18_ft2"), ExtResource("19_ft3")],
"short_name": "冰霜"
},
"mine": {
"description": "定期爆炸，对范围内所有敌人造成高额范围伤害，不会成为敌人的攻击目标。",
"display_name": "地雷",
"levels": [ExtResource("8_m1"), ExtResource("9_m2"), ExtResource("10_m3")],
"short_name": "地雷"
},
"mushroom_tower": {
"description": "发射火球攻击敌人，命中后发生爆炸，对周围敌人造成范围伤害。",
"display_name": "火球塔",
"levels": [ExtResource("14_s1"), ExtResource("15_s2"), ExtResource("16_s3")],
"short_name": "火球"
},
"xiu_xiu": {
"description": "自动发射魔法弹，攻击范围内距离最近的敌人。",
"display_name": "咻咻",
"levels": [ExtResource("2_x1"), ExtResource("3_x2"), ExtResource("4_x3")],
"short_name": "咻咻"
}
}
hotbar_order = PackedStringArray("xiu_xiu", "double_xiu_xiu", "mine", "frost_circle", "mushroom_tower", "frost_tower")
